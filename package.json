{
  "name": "kodara",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib scripts tests proxy.ts eslint.config.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:db": "supabase test db --local supabase/tests/database",
    "test:realtime": "node scripts/realtime-e2e.mjs",
    "check:edge": "deno check --config supabase/functions/deno.json supabase/functions/mpesa-stk-push/index.ts supabase/functions/mpesa-callback/index.ts supabase/functions/mpesa-test-connection/index.ts supabase/functions/etims-submit/index.ts supabase/functions/kodara-subscription-stk-push/index.ts supabase/functions/kodara-subscription-mpesa-callback/index.ts supabase/functions/paystack-initialize/index.ts supabase/functions/paystack-webhook/index.ts",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.9.3",
    "supabase": "^2.109.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
